<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production: HTTPS only for sarhny.com.
         Cloudflare provides a valid public cert; the system trust store
         is enough — no extra <trust-anchors> needed. -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">sarhny.com</domain>
    </domain-config>

    <!-- Local dev: allow HTTP to the Android emulator host (10.0.2.2)
         and loopback so a dev build can hit a local backend. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>

    <!-- Everything else: HTTPS required by default -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
