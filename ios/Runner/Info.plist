<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Sarhny</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>sarhny</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- Privacy purpose strings — required by App Store review. -->
	<!-- Microphone: used to record voice messages in the anonymous inbox. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>يحتاج صارحني للميكروفون لتسجيل الرسائل الصوتية المجهولة وإرسالها داخل المنصة.</string>

	<!-- Camera: used to take photos for post Layer 2 and profile avatar/cover. -->
	<key>NSCameraUsageDescription</key>
	<string>يحتاج صارحني للكاميرا لالتقاط الصور المرفقة بالمنشورات وصورة الملف الشخصي.</string>

	<!-- Photo library: used to pick existing photos for posts + profile + replies. -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>يحتاج صارحني الوصول إلى مكتبة الصور لاختيار الصور المرفقة بالمنشورات والملف الشخصي.</string>

	<!-- Photo library add: only needed if we save images back; future-safe. -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>يحتاج صارحني لحفظ الصور التي تنشئها داخل التطبيق إلى مكتبة الصور.</string>

	<!-- Face ID / biometrics: used by local_auth for fast re-auth. -->
	<key>NSFaceIDUsageDescription</key>
	<string>يستخدم صارحني التعرّف على الوجه لتأمين الدخول السريع لحسابك.</string>

	<!-- Local network: needed by some plugins (e.g. firebase_messaging diagnostics). -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>يستخدم صارحني الاتصال الشبكي المحلي للتحقّق من الخدمات أثناء التشغيل.</string>

	<!-- Export compliance: app only uses Apple's standard HTTPS/TLS — qualifies
	     as exempt encryption under U.S. export regs. Declaring NO here skips
	     the per-build Export Compliance prompt in App Store Connect. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Background modes: lets FCM wake the app for silent / data-only pushes
	     (the "Background fetch" capability + remote-notification capability). -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
